<div class="flex flex-col items-center justify-center min-h-screen py-2 bg-gray-50">
  <div class="p-8 bg-white shadow-md rounded-lg w-full max-w-md">
    <h1 class="text-2xl font-bold mb-6 text-center text-gray-800">Classificados Orange</h1>
    <p class="text-center text-gray-600 mb-8">Faça login para gerenciar artefatos</p>
    {{#if error}}
    <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-4">
      <p class="text-red-700 text-sm">{{error}}</p>
    </div>
    {{/if}}
    <form action="/auth/login" method="POST" class="space-y-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Login</label>
        <input
          type="text"
          name="login"
          required
          class="block w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors"
          placeholder="Digite seu login"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Senha</label>
        <input
          type="password"
          name="password"
          required
          class="block w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors"
          placeholder="Digite sua senha"
        />
      </div>
      <button
        type="submit"
        class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-white bg-orange-600 hover:bg-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 transition-all"
      >
        Entrar
      </button>
    </form>
    <div class="mt-6 text-center text-xs text-gray-400">
      <p>Dica: Use um usuário criado no banco de dados.</p>
    </div>
  </div>
</div>
