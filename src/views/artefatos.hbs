<div class="p-8 max-w-4xl mx-auto">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-800">Meus Artefatos</h1>
    <a
      href="/artefatos/novo"
      class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-2 px-4 rounded-lg transition-colors"
    >
      Novo Artefato
    </a>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-md">
    <ul class="divide-y divide-gray-200">
      {{#if artefatos}}
        {{#each artefatos}}
        <li class="px-6 py-4 flex items-center justify-between hover:bg-gray-50">
          <div>
            <h3 class="text-lg font-medium text-gray-900">{{nome}}</h3>
            <p class="text-sm text-gray-500">Criado em: {{createdAt}}</p>
          </div>
          <div class="flex space-x-3">
            <a
              href="/artefatos/editar/{{id}}"
              class="text-blue-600 hover:text-blue-800 font-medium"
            >
              Editar
            </a>
            <form action="/artefatos/{{id}}/delete" method="POST" class="inline" onsubmit="return window.confirm('Tem certeza que deseja remover este artefato?')">
              <button
                type="submit"
                class="text-red-600 hover:text-red-800 font-medium bg-transparent border-none cursor-pointer"
              >
                Excluir
              </button>
            </form>
          </div>
        </li>
        {{/each}}
      {{else}}
        <li class="p-8 text-center text-gray-500">Nenhum artefato encontrado.</li>
      {{/if}}
    </ul>
  </div>
</div>
