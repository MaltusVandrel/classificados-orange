<div class="p-8 max-w-2xl mx-auto">
  <div class="mb-8">
    <a href="/artefatos" class="text-orange-600 hover:text-orange-800 font-medium">
      &larr; Voltar para a lista
    </a>
    <h1 class="text-3xl font-bold text-gray-800 mt-4">Editar Artefato</h1>
  </div>

  {{#if error}}
  <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-4">
    <p class="text-red-700 text-sm">{{error}}</p>
  </div>
  {{/if}}

  <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
    <form action="/artefatos/editar/{{id}}" method="POST" class="space-y-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Nome do Artefato</label>
        <input
          type="text"
          name="nome"
          value="{{nome}}"
          required
          class="block w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors"
          placeholder="Digite o nome"
        />
      </div>
      <button
        type="submit"
        class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-white bg-orange-600 hover:bg-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 transition-all"
      >
        Atualizar
      </button>
    </form>
  </div>
</div>
